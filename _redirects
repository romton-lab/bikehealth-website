# Cloudflare Workers Static Assets redirects file
# Format: <source> <destination> <status>
# Reference: https://developers.cloudflare.com/workers/static-assets/redirects/
#
# Processed BEFORE asset serving and before html_handling.
# Without this file, Cloudflare auto-handles .html with a 307 (Temporary).
# Google consolidates canonicals better with 301 (Permanent), hence these rules.

# .html aliases (FR)
/index.html               /                       301
/cgu.html                 /cgu                    301
/confidentialite.html     /confidentialite        301
/contact.html             /contact                301
/release-notes.html       /release-notes          301
/notification.html        /notification           301
/notification-pro.html    /notification-pro       301

# .html aliases (EN)
/en/index.html            /en/                    301
/en/terms.html            /en/terms               301
/en/privacy.html          /en/privacy             301
/en/contact.html          /en/contact             301
/en/release-notes.html    /en/release-notes       301
/en/notification.html     /en/notification        301
/en/notification-pro.html /en/notification-pro    301

# Common URL aliases people (and Google) try by default on EN sites
# Fixes the /terms 404 reported in Search Console.
/terms                    /en/terms               301
/privacy                  /en/privacy             301
